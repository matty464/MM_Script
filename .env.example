# Private key of the wallet (or, preferably, an API/agent wallet) you will trade with.
# Use an API wallet (a.k.a. agent wallet): generate one in the Hyperliquid UI and approve it.
# Never put your main wallet's private key here.
HL_PRIVATE_KEY=0xyour_agent_wallet_private_key_here

# The public address of the actual ACCOUNT being traded (your main wallet address).
# Required if HL_PRIVATE_KEY is an agent wallet — the agent signs but funds belong to this address.
# If you are signing with the same wallet that holds the funds, you can leave this blank.
HL_ACCOUNT_ADDRESS=

# Optional: Hyperliquid sub-account / vault address you are trading on behalf of.
HL_VAULT_ADDRESS=
